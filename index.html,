<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VLOR — Exclusive Growth Agency</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --gold-dim: #8B6914;
    --black: #050505;
    --dark: #0D0D0D;
    --dark2: #141414;
    --dark3: #1A1A1A;
    --white: #F5F0E8;
    --white-dim: rgba(245,240,232,0.6);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom Cursor */
  .cursor {
    width: 8px; height: 8px;
    background: var(--gold);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.1s ease;
  }
  .cursor-ring {
    width: 32px; height: 32px;
    border: 1px solid rgba(201,168,76,0.5);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    transition: all 0.15s ease;
  }

  /* Noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 28px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(5,5,5,0.95), transparent);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-links a {
    color: var(--white-dim);
    text-decoration: none;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--gold); }

  .nav-cta {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold) !important;
    border: 1px solid rgba(201,168,76,0.4);
    padding: 10px 24px;
    transition: all 0.3s !important;
  }
  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--black) !important;
  }

  /* HERO */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 120px 40px 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 60%, rgba(201,168,76,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 20% 80%, rgba(201,168,76,0.04) 0%, transparent 60%),
      radial-gradient(ellipse 30% 40% at 80% 20%, rgba(201,168,76,0.03) 0%, transparent 60%);
  }

  .hero-line {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
    margin: 0 auto 50px;
    animation: fadeDown 1.2s ease forwards;
    opacity: 0;
  }

  .hero-eyebrow {
    font-size: 10px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    animation: fadeUp 1s ease 0.3s forwards;
    opacity: 0;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(72px, 14vw, 160px);
    font-weight: 300;
    letter-spacing: 0.15em;
    line-height: 0.9;
    color: var(--white);
    animation: fadeUp 1s ease 0.5s forwards;
    opacity: 0;
    position: relative;
  }

  .hero-title span {
    color: var(--gold);
    font-style: italic;
  }

  .hero-sub {
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--white-dim);
    margin-top: 32px;
    animation: fadeUp 1s ease 0.7s forwards;
    opacity: 0;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 50px auto;
    width: 200px;
    animation: fadeUp 1s ease 0.9s forwards;
    opacity: 0;
  }
  .hero-divider::before, .hero-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-dim));
  }
  .hero-divider::after { background: linear-gradient(to left, transparent, var(--gold-dim)); }
  .hero-diamond {
    width: 6px; height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
  }

  .hero-scroll {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--white-dim);
    animation: fadeUp 1s ease 1.1s forwards;
    opacity: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
  }
  .hero-scroll::after {
    content: '';
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  /* MARQUEE */
  .marquee-section {
    border-top: 1px solid rgba(201,168,76,0.15);
    border-bottom: 1px solid rgba(201,168,76,0.15);
    padding: 20px 0;
    overflow: hidden;
    background: var(--dark2);
  }

  .marquee-track {
    display: flex;
    gap: 60px;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
  }

  .marquee-item {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold-dim);
    display: flex;
    align-items: center;
    gap: 60px;
    flex-shrink: 0;
  }
  .marquee-item::after {
    content: '◆';
    color: var(--gold);
    font-size: 6px;
  }

  /* SECTIONS COMMON */
  section { padding: 120px 60px; }

  .section-label {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .section-label::before {
    content: '';
    width: 30px;
    height: 1px;
    background: var(--gold);
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 24px;
  }

  .section-title em {
    font-style: italic;
    color: var(--gold);
  }

  /* ABOUT */
  #about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .about-text p {
    font-size: 14px;
    line-height: 2;
    color: var(--white-dim);
    margin-bottom: 20px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  .stat-item {
    border-top: 1px solid rgba(201,168,76,0.2);
    padding-top: 24px;
  }

  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 52px;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-dim);
    margin-top: 8px;
  }

  /* SERVICES */
  #services {
    background: var(--dark2);
    max-width: 100%;
  }

  .services-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 60px;
    border: 1px solid rgba(201,168,76,0.1);
  }

  .service-card {
    background: var(--dark3);
    padding: 48px 36px;
    border: 1px solid rgba(201,168,76,0.08);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    transform: scaleX(0);
    transition: transform 0.4s ease;
  }

  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover { background: rgba(201,168,76,0.03); }

  .service-icon {
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 16px;
  }

  .service-price {
    font-size: 13px;
    color: var(--gold);
    letter-spacing: 0.05em;
    margin-bottom: 16px;
    font-weight: 400;
  }

  .service-desc {
    font-size: 12px;
    line-height: 1.8;
    color: rgba(245,240,232,0.4);
  }

  /* PACKAGES */
  #packages {
    max-width: 1200px;
    margin: 0 auto;
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 60px;
  }

  .package-card {
    border: 1px solid rgba(201,168,76,0.15);
    padding: 52px 40px;
    position: relative;
    transition: all 0.4s ease;
    background: var(--dark2);
  }

  .package-card.featured {
    border-color: var(--gold);
    background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, var(--dark2) 100%);
  }

  .package-badge {
    position: absolute;
    top: -1px; right: 32px;
    background: var(--gold);
    color: var(--black);
    font-size: 8px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 6px 16px;
    font-weight: 500;
  }

  .package-tier {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 16px;
  }

  .package-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    font-weight: 300;
    color: var(--white);
    margin-bottom: 8px;
  }

  .package-price {
    font-size: 14px;
    color: var(--gold);
    margin-bottom: 36px;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .package-features {
    list-style: none;
    margin-bottom: 40px;
  }

  .package-features li {
    font-size: 12px;
    color: var(--white-dim);
    padding: 10px 0;
    border-bottom: 1px solid rgba(201,168,76,0.08);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .package-features li::before {
    content: '◆';
    color: var(--gold);
    font-size: 5px;
    flex-shrink: 0;
  }

  .btn {
    display: inline-block;
    padding: 14px 36px;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    cursor: none;
  }

  .btn-outline {
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--gold);
    background: transparent;
    width: 100%;
    text-align: center;
  }
  .btn-outline:hover {
    background: rgba(201,168,76,0.08);
    border-color: var(--gold);
  }

  .btn-gold {
    background: var(--gold);
    color: var(--black);
    border: 1px solid var(--gold);
    width: 100%;
    text-align: center;
  }
  .btn-gold:hover {
    background: var(--gold-light);
  }

  /* CONTACT */
  #contact {
    background: var(--dark2);
    text-align: center;
  }

  .contact-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-inner .section-label { justify-content: center; }
  .contact-inner .section-label::before { display: none; }

  .contact-phone {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 300;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin: 40px 0 20px;
    display: block;
    text-decoration: none;
    transition: color 0.3s;
  }
  .contact-phone:hover { color: var(--gold-light); }

  .contact-tagline {
    font-size: 12px;
    color: var(--white-dim);
    letter-spacing: 0.2em;
    margin-bottom: 50px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .form-input {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,168,76,0.2);
    color: var(--white);
    padding: 16px 20px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    outline: none;
    transition: border-color 0.3s;
    width: 100%;
  }
  .form-input:focus { border-color: var(--gold); }
  .form-input::placeholder { color: rgba(245,240,232,0.3); }

  textarea.form-input { height: 120px; resize: vertical; }

  .form-submit {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 16px;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    cursor: none;
    transition: all 0.3s;
    width: 100%;
  }
  .form-submit:hover { background: var(--gold); color: var(--black); }

  /* FOOTER */
  footer {
    padding: 40px 60px;
    border-top: 1px solid rgba(201,168,76,0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    letter-spacing: 0.3em;
    color: var(--gold);
  }

  .footer-copy {
    font-size: 10px;
    color: rgba(245,240,232,0.3);
    letter-spacing: 0.15em;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.3; transform: scaleY(0.5); }
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    nav { padding: 24px 24px; }
    .nav-links { display: none; }
    section { padding: 80px 24px; }
    #about { grid-template-columns: 1fr; gap: 60px; }
    .services-grid { grid-template-columns: 1fr; }
    .packages-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 16px; text-align: center; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <a href="#hero" class="nav-logo">VLOR</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#packages">Packages</a></li>
    <li><a href="#contact" class="nav-cta">Book a Call</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-line"></div>
  <p class="hero-eyebrow">Exclusive Growth Agency · Est. 2025</p>
  <h1 class="hero-title">VL<span>O</span>R</h1>
  <p class="hero-sub">Precision &nbsp;·&nbsp; Prestige &nbsp;·&nbsp; Performance</p>
  <div class="hero-divider"><div class="hero-diamond"></div></div>
  <p style="font-size:14px; color:var(--white-dim); line-height:1.9; max-width:500px; animation: fadeUp 1s ease 0.9s forwards; opacity:0;">
    Where bold brands are built.<br>We craft growth strategies for brands that refuse to be ordinary.
  </p>
  <div class="hero-scroll" style="margin-top: 60px;">Scroll</div>
</section>

<!-- MARQUEE -->
<div class="marquee-section">
  <div class="marquee-track">
    <span class="marquee-item">Website Development</span>
    <span class="marquee-item">Paid Advertising</span>
    <span class="marquee-item">Funnel Optimization</span>
    <span class="marquee-item">Email Marketing</span>
    <span class="marquee-item">Creative Services</span>
    <span class="marquee-item">Brand Strategy</span>
    <span class="marquee-item">Website Development</span>
    <span class="marquee-item">Paid Advertising</span>
    <span class="marquee-item">Funnel Optimization</span>
    <span class="marquee-item">Email Marketing</span>
    <span class="marquee-item">Creative Services</span>
    <span class="marquee-item">Brand Strategy</span>
  </div>
</div>

<!-- ABOUT -->
<section>
  <div id="about" class="reveal">
    <div class="about-text">
      <p class="section-label">Our Story</p>
      <h2 class="section-title">Built by two sisters.<br><em>Driven by results.</em></h2>
      <p>Vlor is a boutique marketing and business development agency founded on one belief: exceptional brands deserve exceptional growth. We combine strategy, creativity, and precision to deliver outcomes that matter.</p>
      <p>From local Canadian businesses to international e-commerce brands, we partner with clients who are serious about scaling — and we treat every project as if it were our own.</p>
    </div>
    <div class="about-stats">
      <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">Client Focused</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">5★</div>
        <div class="stat-label">Service Standard</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">3x</div>
        <div class="stat-label">Avg. Growth Target</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">CA</div>
        <div class="stat-label">Based in Canada</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services">
  <div class="services-inner">
    <p class="section-label reveal">What We Offer</p>
    <h2 class="section-title reveal">Our <em>Services</em></h2>
    <div class="services-grid reveal">
      <div class="service-card">
        <div class="service-icon">01 · Web</div>
        <div class="service-name">Website Development</div>
        <div class="service-price">From $1,500 CAD</div>
